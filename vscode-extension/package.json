{
   "name": "abap-cleaner",
   "displayName": "ABAP cleaner",
   "description": "ABAP cleaner applies 100+ cleanup rules to ABAP code at a single keystroke.",
   "version": "1.28.4",
   "publisher": "SAPOSS",
   "engines": {
      "vscode": "^1.109.0"
   },
   "license": "Apache-2.0",
   "categories": [
      "Formatters"
   ],
   "keywords": [
      "ABAP cleaner",
      "ABAP",
      "Clean Code",
      "Clean ABAP",
      "ABAP Formatter",
      "Pretty Printer",
      "formatter",
      "automated cleanup",
      "interactive cleanup",
      "code cleanup",
      "code formatting",
      "code refactoring",
      "code modernization",
      "code optimization",
      "code quality",
      "code readability",
      "code maintainability",
      "CDS Views",
      "Data Definition Language",
      "DDL"
   ],
   "preview": false,
   "main": "./out/extension.js",
   "contributes": {
      "commands": [
         {
            "command": "abapCleaner.formatDocument",
            "title": "ABAP Cleaner: Format Document",
            "category": "ABAP"
         },
         {
            "command": "abapCleaner.formatSelection",
            "title": "ABAP Cleaner: Format Selection",
            "category": "ABAP"
         },
         {
            "command": "abapCleaner.formatInteractively",
            "title": "ABAP Cleaner: Format Interactively",
            "category": "ABAP"
         },
         {
            "command": "abapCleaner.readOnlyPreview",
            "title": "ABAP Cleaner: Show Read-Only Preview",
            "category": "ABAP"
         }
      ],
      "keybindings": [
         {
            "command": "editor.action.formatDocument",
            "key": "ctrl+5",
            "mac": "cmd+5",
            "when": "editorTextFocus && (resourceExtname == .abap || resourceExtname == .acds)"
         },
         {
            "command": "editor.action.formatSelection",
            "key": "ctrl+4",
            "mac": "cmd+4",
            "when": "editorTextFocus && (resourceExtname == .abap || resourceExtname == .acds)"
         },
         {
            "command": "abapCleaner.formatInteractively",
            "key": "ctrl+shift+4",
            "mac": "cmd+shift+4",
            "when": "editorTextFocus && (resourceExtname == .abap || resourceExtname == .acds)"
         },
         {
            "command": "abapCleaner.readOnlyPreview",
            "key": "ctrl+shift+5",
            "mac": "cmd+shift+5",
            "when": "editorTextFocus && (resourceExtname == .abap || resourceExtname == .acds)"
         }
      ],
      "configuration": {
         "title": "ABAP Cleaner",
         "properties": {
            "abapCleaner.debugMode": {
               "type": "boolean",
               "default": false,
               "description": "Enable debug logging for ABAP cleaner"
            }
         }
      }
   },
   "activationEvents": [
      "onStartupFinished",
      "onFileSystem:abap",
      "onFileSystem:acds",
      "onLanguage:abap",
      "onLanguage:acds"
   ],
   "qna": "https://github.com/SAP/abap-cleaner/issues",
   "devDependencies": {
      "@types/node": "22.19.19",
      "@types/vscode": "1.109.0",
      "@vscode/vsce": "3.9.2",
      "typescript": "6.0.3"
   },
   "extensionKind": [
      "ui"
   ],
   "scripts": {
      "compile": "tsc -p .",
      "watch": "tsc -watch -p .",
      "lint": "tsc --noEmit -p .",
      "package": "npm run compile && vsce package"
   },
   "icon": "abap-cleaner.png",
   "pricing": "Free",
   "capabilities": {
      "virtualWorkspaces": true,
      "untrustedWorkspaces": {
         "supported": false,
         "description": "This extension launches a native Eclipse RCP executable."
      }
   },
   "bugs": {
      "url": "https://github.com/SAP/abap-cleaner/issues"
   },
   "repository": {
      "type": "git",
      "url": "https://github.com/SAP/abap-cleaner.git"
   },
   "homepage": "https://github.com/SAP/abap-cleaner"
}
